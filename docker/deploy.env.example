# Copy next to docker-compose.prod.yml as docker/.env:
#   cp docker/deploy.env.example docker/.env
#
# Used by: docker compose -f docker/docker-compose.prod.yml
# See docs/DEPLOY.md for the full configuration reference.

# ── Required ──
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Public URL users visit (no trailing slash). Used for CORS.
# Use https:// when TLS is enabled (see docs/DEPLOY.md § HTTPS).
# Example: https://blog.example.com
CORS_ORIGIN=https://YOUR_DOMAIN

# ── Image registry (CI overwrites these on each deploy) ──
# For GitHub Actions + GHCR, use: ghcr.io/<owner>/<repo>
# Example: ghcr.io/myorg/my-blog
IMAGE_REGISTRY=ghcr.io/OWNER/REPO
IMAGE_TAG=latest

# Docker Compose stack name (container name prefix: <name>-api-1, etc.)
COMPOSE_PROJECT_NAME=app

# ── HTTP port exposed on the host ──
HTTP_PORT=80

# ── HTTPS port exposed on the host (TLS certs mounted from ../certs) ──
HTTPS_PORT=443

# ── Optional: JWT lifetime ──
JWT_EXPIRES_IN=3h

# ── Optional: Alibaba Cloud OSS (S3-compatible) for image storage ──
# STORAGE_USE_OBJECT_STORE=true
# S3_BUCKET=your-bucket
# S3_REGION=oss-cn-hangzhou
# S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
# S3_KEY_PREFIX=uploads/
# S3_FORCE_PATH_STYLE=false
