# API
PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/blog
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=3h
UPLOAD_DIR=uploads
CORS_ORIGIN=http://localhost:5173

# Image storage
# development/test: keep local (toggle off in settings)
# production: configure S3 and set STORAGE_USE_OBJECT_STORE=true
STORAGE_USE_OBJECT_STORE=false
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_KEY_PREFIX=uploads/
S3_FORCE_PATH_STYLE=false

# Web (apps/web/.env)
VITE_API_BASE_URL=http://localhost:3000/api
