# API
PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/blog
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=3h
UPLOAD_DIR=uploads
CORS_ORIGIN=http://localhost:5173

# Image storage
# development/test: keep local (toggle off in settings)
# production: configure OSS and set STORAGE_USE_OBJECT_STORE=true
STORAGE_USE_OBJECT_STORE=false
OSS_BUCKET=
OSS_REGION=oss-cn-beijing
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
OSS_PUBLIC_BASE_URL=
OSS_KEY_PREFIX=uploads/
OSS_FORCE_PATH_STYLE=false

# Web (apps/web/.env) — dev only; production build uses /api via nginx gateway
VITE_API_BASE_URL=/api

# ── Production deployment (see docker/deploy.env.example and docs/DEPLOY.md) ──
# Production: copy docker/deploy.env.example to server as docker/.env
# e.g. /opt/app/docker/.env (see docs/DEPLOY.md)
